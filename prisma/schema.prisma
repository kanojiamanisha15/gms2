// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int      @id @default(autoincrement())
  name                String
  email               String   @unique
  password            String
  role                String   @default("user")
  permissions         String[] @default([])
  gymId               Int?     @map("gym_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @map("updated_at")

  gym Gym? @relation(fields: [gymId], references: [gymId])

  @@map("users")
}

model Gym {
  gymId     Int      @id @default(autoincrement()) @map("gym_id")
  gymName   String   @map("gym_name")
  address   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  users           User[]
  members         Member[]
  trainers        Trainer[]
  membershipPlans MembershipPlan[]
  expenses        Expense[]
  banks           Bank[]
  attendances     Attendance[]
  notifications   Notification[]

  @@unique([gymName, address], map: "gyms_gym_name_address_key")
  @@map("gyms")
}

model Member {
  id             Int       @id @default(autoincrement())
  memberId       String    @unique @map("member_id")
  name           String
  email          String?   // nullable in SQL
  phone          String?   // nullable in SQL
  membershipType String    @map("membership_type")
  joinDate       DateTime  @default(now()) @map("join_date")
  expiryDate     DateTime? @map("expiry_date")
  status         String    @default("active")
  paymentStatus  String    @default("unpaid") @map("payment_status")
  paymentMode    String?   @map("payment_mode")
  paymentAmount  Decimal   @default(0.0) @db.Decimal(10, 2) @map("payment_amount")
  bankId         Int?      @map("bank_id")
  gymId          Int?      @map("gym_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @map("updated_at")

  gym      Gym?     @relation(fields: [gymId], references: [gymId])
  bank     Bank?    @relation(fields: [bankId], references: [id])

  @@map("members")
}

model MembershipPlan {
  id           Int      @id @default(autoincrement())
  name         String
  price        Decimal  @db.Decimal(10, 2)
  durationDays String   @map("duration_days")
  features     String?
  status       String   @default("active")
  gymId        Int?     @map("gym_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")
  gym          Gym?     @relation(fields: [gymId], references: [gymId])

  @@map("membership_plans")
}

model Expense {
  id          Int      @id @default(autoincrement())
  category    String
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime
  status      String   @default("pending")
  vendor      String?
  gymId       Int?     @map("gym_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")
  gym         Gym?     @relation(fields: [gymId], references: [gymId])

  @@map("expenses")
}

model Attendance {
  id           Int      @id @default(autoincrement())
  memberId     String   @map("member_id")
  memberName   String   @map("member_name")
  gymId        Int?     @map("gym_id")
  checkInDate  DateTime @map("check_in_date")
  checkInTime  String   @map("check_in_time")
  checkOutDate DateTime? @map("check_out_date")
  checkOutTime String?  @map("check_out_time")
  status       String
  duration     String?  // stored as VARCHAR(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")
  gym          Gym?     @relation(fields: [gymId], references: [gymId])

  @@map("attendance")
}

model Trainer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String
  role      String
  hireDate  DateTime @map("hire_date")
  status    String   @default("active")
  gymId     Int?     @map("gym_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  gym       Gym?     @relation(fields: [gymId], references: [gymId])

  @@map("trainers")
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String
  gymId     Int?     @map("gym_id")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  gym       Gym?     @relation(fields: [gymId], references: [gymId])

  @@map("notifications")
}

model Bank {
  id                Int      @id @default(autoincrement())
  bankName          String   @map("bank_name")
  accountNumber     String?  @map("account_number")
  ifscCode          String?  @map("ifsc_code")
  accountHolderName String   @map("account_holder_name")
  branchName        String   @map("branch_name")
  accountType       String   @map("account_type")
  upiId             String?  @map("upi_id")
  gymId             Int?     @map("gym_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")
  gym               Gym?     @relation(fields: [gymId], references: [gymId])
  members           Member[]

  @@map("banks")
}
