# Application Configuration
# Copy this file to .env.local and fill in your actual values

# ============================================
# Application Settings
# ============================================
# Public URL of your application (used for API calls)
# In development, this is typically http://localhost:3000
# In production, use your actual domain (e.g., https://yourdomain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment (development, production, test)
# Next.js automatically sets this, but you can override if needed
NODE_ENV=development

# ============================================
# Authentication & Security
# ============================================
# JWT Secret Key - MUST be changed in production!
# Generate a strong random string (at least 32 characters)
# You can generate one using: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# JWT Token Expiration Time
# Format: number followed by unit (s, m, h, d)
# Examples: 1h, 24h, 7d, 30d
JWT_EXPIRES_IN=7d

# ============================================
# Database Configuration
# ============================================
# PostgreSQL Database Host
DB_HOST=localhost

# PostgreSQL Database Port
DB_PORT=5432

# Database Name
DB_NAME=gms

# Database User
DB_USER=postgres

# Database Password
DB_PASSWORD=1234

# Database SSL Configuration
# Set to 'true' if your database requires SSL (e.g., production databases)
# Set to 'false' for local development
DB_SSL=false

# Default user (created when running db-init)
DEFAULT_USER_EMAIL=admin@gmail.com
DEFAULT_USER_PASSWORD=Admin@123
DEFAULT_USER_NAME=admin
DEFAULT_USER_ROLE=Admin

# ============================================
# Default User (for db-init.ts seed)
